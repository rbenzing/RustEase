{
  "name": "rustease",
  "version": "1.0.0",
  "description": "RustEase — a simple language that compiles to Rust",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "bin": {
    "rustease": "./dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx src/cli/cli.ts",
    "start": "node dist/cli/cli.js",
    "prepublishOnly": "npm run build && npm test",
    "bundle": "node scripts/bundle.js",
    "package": "node scripts/package-exe.js",
    "release:build": "npm run build && npm run bundle && npm run package",
    "release": "release-it"
  },
  "keywords": [
    "compiler",
    "transpiler",
    "rust",
    "language",
    "cli"
  ],
  "license": "AGPL-3.0-only",
  "author": "RustEase Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RustEase/RustEase.git"
  },
  "homepage": "https://github.com/RustEase/RustEase#readme",
  "bugs": {
    "url": "https://github.com/RustEase/RustEase/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "release-it": "^19.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
