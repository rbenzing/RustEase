{
  "$schema": "https://unpkg.com/release-it@latest/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "RustEase v${version}",
    "assets": [
      "release/rustease-v*.zip"
    ]
  },
  "hooks": {
    "after:bump": "npm run release:build"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
